{
  "name": "venas-radio",
  "version": "0.0.0",
  "description": "A radio player by and for Vena.",
  "private": true,
  "scripts": {
    "dev": "cd src/app && vite & yarn server",
    "build": "yarn lint && (tsc -p ./tsconfig.build.json & (cd src/app && yarn vite build))",
    "start": "node dist-server/api/server.js",
    "server": "tsx --watch src/api/server.ts",
    "lint": "tsc --noEmit -p ./tsconfig.json && eslint -c ./eslint.config.ts --cache --concurrency auto",
    "api:types": "tsx scripts/api-scanner.ts"
  },
  "dependencies": {
    "express": "^5.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/express": "^5",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jiti": "^2.6.1",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10"
  },
  "packageManager": "yarn@4.14.1",
  "type": "module"
}