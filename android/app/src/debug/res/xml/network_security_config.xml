<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only. Android blocks cleartext HTTP by default from targetSdk 28, which
  is right, but the dev server runs plain http on the workstation.

  base-config rather than a domain list: the dev server's address is whatever
  `vradio.apiBaseUrl` in local.properties says (a LAN IP that follows DHCP), so
  pinning domains here would silently break every time it changes.

  Release builds never see this file, so they keep cleartext blocked entirely.
-->
<network-security-config>
  <base-config cleartextTrafficPermitted="true" />
</network-security-config>
