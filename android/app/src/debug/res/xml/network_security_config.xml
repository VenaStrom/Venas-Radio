<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only. Android blocks cleartext HTTP by default from targetSdk 28, which
  is right, but the dev server runs plain http on the workstation.

  Scoped to loopback rather than a blanket usesCleartextTraffic="true":
    localhost  reached from the device via `adb reverse tcp:3000 tcp:3000`
    10.0.2.2   the host machine as seen from an emulator

  Release builds never see this file, so they keep cleartext blocked entirely.
-->
<network-security-config>
  <domain-config cleartextTrafficPermitted="true">
    <domain includeSubdomains="false">localhost</domain>
    <domain includeSubdomains="false">127.0.0.1</domain>
    <domain includeSubdomains="false">10.0.2.2</domain>
  </domain-config>
</network-security-config>
