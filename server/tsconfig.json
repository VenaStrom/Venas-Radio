{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    // Node-only backend, so no DOM lib. window/document/localStorage will not type-check.
    "lib": [
      "esnext",
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "allowUnreachableCode": false,
    "noUncheckedIndexedAccess": true,
    // "noPropertyAccessFromIndexSignature": true,
    "paths": {
      "@/*": [
        "./src/*",
      ],
    },
    "types": [
      "node",
    ],
    "noEmit": true,
  },
  "include": [
    "**/*.ts",
  ],
  "exclude": [
    "node_modules",
    "build",
    "prisma/generated",
    "src/prisma/"
  ],
}
