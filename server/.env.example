# Copy to .env and fill in. .env is gitignored.

DATABASE_URL="mysql://user:password@localhost:3306/venas_radio2"

# From https://discord.com/developers/applications -> your app -> OAuth2.
# The redirect below must be registered there byte-for-byte.
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_REDIRECT_URI="http://localhost:3000/auth/discord/callback"

# Where the browser hands control back to the Android app. Must match the
# build type's authScheme in android/app/build.gradle.kts:
#   debug   -> vradio-debug://auth
#   release -> vradio://auth
APP_REDIRECT_SCHEME="vradio-debug://auth"


# Where the Android app can reach the server
VRADIO_API_URL="http://localhost:3000"