{
  "name": "venas-radio-server",
  "version": "0.0.0",
  "description": "Backend for Vena's Radio. Serves SR metadata, user state and cached episode audio to the Android client.",
  "private": true,
  "scripts": {
    "dev": "tsx --watch src/api/server.ts",
    "build": "yarn lint",
    "start": "tsx src/api/server.ts",
    "lint": "tsc --noEmit -p ./tsconfig.json && eslint -c ./eslint.config.ts --cache --concurrency auto",
    "api:types": "tsx scripts/api-scanner.ts",
    "rm-dist": "rm -rf .cache-seed scripts/.cache .eslintcache tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.5",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "jiti": "^2.7.0",
    "prisma": "^7.8.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  },
  "packageManager": "yarn@4.17.1+sha512.ccbfabf7d7b6b32075088be9386fb9a2e00bb6887ef07fa56effabc890a56d53da1ccc4128d62db245fcbd3961b236d75335bdf7d5320ed6eafb7588b7ad4697",
  "type": "module"
}
