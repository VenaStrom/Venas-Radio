generator client {
  provider     = "prisma-client"
  moduleFormat = "esm"
  output       = "./generated"
}

datasource db {
  provider = "mysql"
}

model User {
  // Might just do clerk id :woman_shrugging:
  id            Int       @id
  likedChannels Channel[]
  likedPrograms Program[]
}

model Progress {
  episodeId Int
  userId    Int
  progress  Int

  @@id([episodeId, userId])
}

model Channel {
  id            Int        @id
  name          String
  image         String
  imageTemplate String
  color         String
  tagline       String
  siteUrl       String
  scheduleUrl   String?
  channelType   String
  xmltvId       String?
  liveAudio     LiveAudio?
  programs      Program[]
  user          User?      @relation(fields: [userId], references: [id])
  userId        Int?
}

model LiveAudio {
  id        Int     @id
  url       String
  statKey   String
  channelId Int     @unique
  channel   Channel @relation(fields: [channelId], references: [id])
}

model Episode {
  id                Int                   @id
  title             String
  description       String
  url               String
  audioPreference   String
  audioPriority     String
  audioPresentation String
  publishDateUtc    String
  imageUrl          String
  imageUrlTemplate  String
  photographer      String
  programId         Int
  program           Program               @relation(fields: [programId], references: [id])
  broadcast         EpisodeBroadcast?
  broadcastTime     EpisodeBroadcastTime?
}

model Program {
  id                       Int                   @id
  name                     String
  description              String
  email                    String
  phone                    String
  programUrl               String
  programSlug              String?
  broadcastInfo            String?
  payoff                   String?
  programCategoryId        Int?
  programCategory          ProgramCategory?      @relation(fields: [programCategoryId], references: [id])
  hasOnDemand              Boolean
  hasPod                   Boolean
  archived                 Boolean
  programImage             String
  programImageTemplate     String
  programImageTemplateWide String
  programImageWide         String
  socialImage              String
  socialImageTemplate      String
  responsibleEditor        String
  channelId                Int
  channel                  Channel               @relation(fields: [channelId], references: [id])
  socialMediaPlatforms     SocialMediaPlatform[]
  episodes                 Episode[]
  user                     User?                 @relation(fields: [userId], references: [id])
  userId                   Int?
}

model ProgramCategory {
  id       Int       @id
  name     String
  programs Program[]
}

model SocialMediaPlatform {
  platform    String
  platformUrl String
  programId   Int
  program     Program @relation(fields: [programId], references: [id])

  @@id([programId, platform])
  @@unique([programId, platform])
}

model EpisodeBroadcast {
  episodeId        Int                       @id
  availableStopUtc String
  episode          Episode                   @relation(fields: [episodeId], references: [id])
  playlist         EpisodeBroadcastPlaylist?
  broadcastFiles   EpisodeBroadcastFile[]
}

model EpisodeBroadcastPlaylist {
  broadcastId    Int              @id
  duration       Int
  publishDateUtc String
  url            String
  statKey        String
  broadcast      EpisodeBroadcast @relation(fields: [broadcastId], references: [episodeId])
}

model EpisodeBroadcastFile {
  id             Int              @id
  duration       Int
  publishDateUtc String
  url            String
  statKey        String
  broadcastId    Int
  broadcast      EpisodeBroadcast @relation(fields: [broadcastId], references: [episodeId])

  @@index([broadcastId])
}

model EpisodeBroadcastTime {
  episodeId    Int     @id
  startTimeUtc String
  endTimeUtc   String
  episode      Episode @relation(fields: [episodeId], references: [id])
}
